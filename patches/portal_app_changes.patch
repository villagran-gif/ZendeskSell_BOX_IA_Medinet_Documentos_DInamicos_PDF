+// -------------------------
+// Estatura (cm) guard:
+// - Preferimos cm enteros (ej: 175)
+// - Si el usuario escribe metros (ej: 1.75 / 1,75) lo convertimos a cm al salir
+// -------------------------
+function enforceHeightFormat(inputEl) {
+  if (!inputEl) return;
+
+  const sanitize = () => {
+    let v = inputEl.value || "";
+    // permitir solo dígitos, punto o coma
+    v = v.replace(/[^\d.,]/g, "");
+
+    // permitir solo 1 separador (normalizamos a ".")
+    const firstSepIndex = v.search(/[.,]/);
+    if (firstSepIndex !== -1) {
+      const before = v.slice(0, firstSepIndex).replace(/[.,]/g, "");
+      const afterRaw = v.slice(firstSepIndex + 1).replace(/[.,]/g, "");
+      const after = afterRaw.slice(0, 2); // max 2 decimales si viene en metros
+      v = before + "." + after;
+    } else {
+      v = v.replace(/[.,]/g, "");
+    }
+
+    inputEl.value = v;
+  };
+
+  inputEl.addEventListener("input", sanitize);
+
+  inputEl.addEventListener("blur", () => {
+    const cm = parseHeightToCmStrict(inputEl.value);
+    if (cm !== null) inputEl.value = String(cm);
+  });
+}
+
+// Estatura -> cm (estricto y robusto)
+// - Acepta: "175" (cm) o "1.75" / "1,75" (m)
+// - Devuelve entero cm, o null si inválido
+function parseHeightToCmStrict(raw) {
+  const s0 = String(raw || "").trim();
+  if (!s0) return null;
+  const s = s0.replace(",", ".").replace(/[^\d.]/g, "");
+  if (!s) return null;
+
+  // metros con decimales
+  if (s.includes(".")) {
+    if (!/^\d+(\.\d{1,2})?$/.test(s)) return null;
+    const m = Number(s);
+    if (!Number.isFinite(m)) return null;
+    if (m < 1.0 || m > 2.5) return null;
+    return Math.round(m * 100);
+  }
+
+  // cm enteros
+  if (!/^\d+$/.test(s)) return null;
+  const cm = Number(s);
+  if (!Number.isFinite(cm)) return null;
+  if (cm < 80 || cm > 250) return null;
+  return Math.round(cm);
+}
